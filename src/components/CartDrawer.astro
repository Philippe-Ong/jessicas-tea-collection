---
---
<aside
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-label="Warenkorb"
  aria-modal="true"
  aria-hidden="true"
>
  <div class="cart-drawer-inner">
    <div class="cart-header">
      <h2 class="cart-heading">Warenkorb</h2>
      <button id="cart-close" class="cart-close" aria-label="Warenkorb schliessen">✕</button>
    </div>

    <div class="cart-content">
      <div id="cart-items" class="cart-items">
        <p class="cart-empty">Ihr Warenkorb ist leer.</p>
      </div>

      <div id="cart-progress" class="cart-progress"></div>

      <div class="cart-summary">
        <div class="cart-row">
          <span>Zwischensumme</span>
          <span id="cart-subtotal">CHF 0.00</span>
        </div>
        <div class="cart-row">
          <span>Versand</span>
          <span id="cart-shipping">CHF 0.00</span>
        </div>
        <div class="cart-row cart-row--discount">
          <span>Rabatt</span>
          <span id="cart-discount">CHF 0.00</span>
        </div>
        <div class="cart-row cart-row--total">
          <span>Total</span>
          <span id="cart-total">CHF 0.00</span>
        </div>
      </div>

      <button id="cart-checkout-btn" class="cart-checkout-btn" disabled>
        Zur Kasse
      </button>
    </div>
  </div>
</aside>

<div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

<style is:global>
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 380px;
    max-width: 100vw;
    background: var(--color-white);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    box-shadow: -4px 0 20px rgba(0,0,0,0.1);
  }

  .cart-drawer.open {
    transform: translateX(0);
  }

  .cart-drawer-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .cart-heading {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .cart-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    padding: var(--space-2);
    color: var(--color-text);
  }

  .cart-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    gap: var(--space-5);
    overflow-y: auto;
  }

  .cart-items {
    flex: 1;
  }

  .cart-empty {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-align: center;
    padding: var(--space-7) 0;
  }

  .cart-progress {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .cart-summary {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .cart-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .cart-row--discount {
    color: var(--color-sage);
  }

  .cart-row--total {
    font-weight: 600;
    font-size: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
  }

  .cart-checkout-btn {
    width: 100%;
    padding: 14px 24px;
    background: var(--color-terracotta);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cart-checkout-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-checkout-btn:not(:disabled):hover {
    background: var(--color-terracotta-banner);
  }

  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .cart-drawer.open ~ .cart-overlay {
    opacity: 1;
    pointer-events: auto;
  }
</style>
