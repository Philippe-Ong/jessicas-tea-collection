---
---
<aside
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-label="Warenkorb"
  aria-modal="true"
  aria-hidden="true"
>
  <div class="cart-drawer-inner">
    <div class="cart-header">
      <h2 class="cart-heading">Warenkorb</h2>
      <button id="cart-close" class="cart-close" aria-label="Warenkorb schliessen">✕</button>
    </div>

    <div class="cart-content">
      <div id="cart-items" class="cart-items">
        <p class="cart-empty">Ihr Warenkorb ist leer.</p>
      </div>

      <div id="cart-progress" class="cart-progress"></div>

      <div class="cart-summary">
        <div class="cart-row">
          <span>Zwischensumme</span>
          <span id="cart-subtotal">CHF 0.00</span>
        </div>
        <div class="cart-row">
          <span>Versand</span>
          <span id="cart-shipping">CHF 0.00</span>
        </div>
        <div class="cart-row cart-row--discount">
          <span>Rabatt</span>
          <span id="cart-discount">CHF 0.00</span>
        </div>
        <div class="cart-row cart-row--total">
          <span>Total</span>
          <span id="cart-total">CHF 0.00</span>
        </div>
      </div>

      <button id="cart-checkout-btn" class="cart-checkout-btn" disabled>
        Zur Kasse
      </button>

      <div id="cart-checkout-note" class="cart-checkout-note" hidden>
        <p>Der Online-Checkout ist noch nicht verfügbar. Senden Sie uns Ihre Bestellung ganz einfach per E-Mail oder WhatsApp – Ihre Auswahl ist bereits vorbereitet:</p>
        <div class="cart-order-actions">
          <a id="cart-order-email" class="cart-order-link cart-order-link--email" href="#">Per E-Mail bestellen</a>
          <a id="cart-order-whatsapp" class="cart-order-link cart-order-link--whatsapp" href="#" target="_blank" rel="noopener noreferrer">Per WhatsApp bestellen</a>
        </div>
      </div>
    </div>
  </div>
</aside>

<div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

<style is:global>
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 380px;
    max-width: 100vw;
    background: var(--color-white);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    box-shadow: -4px 0 20px rgba(0,0,0,0.1);
  }

  .cart-drawer.open {
    transform: translateX(0);
  }

  .cart-drawer-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .cart-heading {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .cart-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    padding: var(--space-2);
    color: var(--color-text);
  }

  .cart-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    gap: var(--space-5);
    overflow-y: auto;
  }

  .cart-items {
    flex: 1;
  }

  .cart-empty {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-align: center;
    padding: var(--space-7) 0;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'info remove'
      'price price'
      'qty total';
    row-gap: var(--space-2);
    column-gap: var(--space-3);
    align-items: center;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-item:first-child {
    padding-top: 0;
  }

  .cart-item:last-child {
    border-bottom: none;
  }

  .cart-item-info {
    grid-area: info;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .cart-item-name {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .cart-item-cn {
    font-family: var(--font-serif);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .cart-item-price {
    grid-area: price;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .cart-item-qty {
    grid-area: qty;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-white);
  }

  .cart-qty-btn {
    width: 28px;
    height: 28px;
    border: none;
    background: var(--color-cream);
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .cart-qty-btn:hover {
    background: var(--color-sand);
  }

  .cart-qty-input {
    width: 40px;
    height: 28px;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-white);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .cart-qty-input::-webkit-inner-spin-button,
  .cart-qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-item-total {
    grid-area: total;
    justify-self: end;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .cart-item-remove {
    grid-area: remove;
    justify-self: end;
    align-self: start;
    background: none;
    border: none;
    padding: 2px 4px;
    color: var(--color-text-light);
    font-size: 0.85rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
  }

  .cart-item-remove:hover {
    color: var(--color-terracotta);
  }

  .cart-progress {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .cart-summary {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .cart-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .cart-row--discount {
    color: var(--color-sage);
  }

  .cart-row--total {
    font-weight: 600;
    font-size: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
  }

  .cart-checkout-btn {
    width: 100%;
    padding: 14px 24px;
    background: var(--color-terracotta);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cart-checkout-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-checkout-btn:not(:disabled):hover {
    background: var(--color-terracotta-banner);
  }

  .cart-checkout-note {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-cream);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .cart-checkout-note[hidden] {
    display: none;
  }

  .cart-order-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .cart-order-link {
    flex: 1;
    min-width: 140px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 0.85rem;
    text-align: center;
    color: var(--color-white);
    transition: opacity 0.2s;
  }

  .cart-order-link:hover {
    opacity: 0.85;
  }

  .cart-order-link--email {
    background: var(--color-olive);
  }

  .cart-order-link--whatsapp {
    background: #25D366;
  }

  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .cart-drawer.open ~ .cart-overlay {
    opacity: 1;
    pointer-events: auto;
  }
</style>
