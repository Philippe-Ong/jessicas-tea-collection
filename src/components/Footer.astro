---
import { site } from '../data/site';

const year = new Date().getFullYear();

const footerLinks = [
  { label: 'Kontakt', href: '/kontakt' },
  { label: 'Infokasten', href: '/infokasten' },
  { label: 'Bestellung & Versand', href: '/bestellung-versand' },
  { label: 'Rückgabe', href: '/rueckgabe' },
  { label: 'AGB', href: '/agb' },
  { label: 'Allergie-Hinweis', href: '/allergie-hinweis' },
  { label: 'Datenschutz', href: '/datenschutz' },
  { label: 'Impressum', href: '/impressum' },
];
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo-mark">茶</span>
      <span class="footer-brand-name">{site.name}</span>
      <p class="footer-tagline">{site.tagline}</p>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">Links</h4>
      <nav aria-label="Footer Navigation">
        {footerLinks.map(link => (
          <a href={link.href} class="footer-link">{link.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">Kontakt</h4>
      <address class="footer-address">
        {site.address.line1}<br />
        {site.address.street}<br />
        {site.address.zip} {site.address.city}<br />
        {site.address.floor && <>{site.address.floor}<br /></>}
        <a href={`mailto:${site.email}`}>{site.email}</a><br />
        <a href={`tel:${site.phone}`}>{site.phone}</a>
      </address>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} {site.name}. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    background: var(--color-text);
    color: var(--color-cream);
    padding: var(--space-8) 0 0;
    margin-top: var(--space-9);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-7);
    padding-bottom: var(--space-7);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-terracotta);
    color: var(--color-white);
    font-size: 1.25rem;
    font-family: var(--font-serif);
    border-radius: 4px;
  }

  .footer-brand-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .footer-tagline {
    font-style: italic;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .footer-heading {
    font-family: var(--font-serif);
    font-size: 1rem;
    margin-bottom: var(--space-4);
    color: var(--color-ochre);
  }

  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: 0.875rem;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .footer-link:hover {
    opacity: 1;
    color: var(--color-sage);
  }

  .footer-address {
    font-style: normal;
    font-size: 0.875rem;
    line-height: 1.8;
    opacity: 0.85;
  }

  .footer-address a {
    color: var(--color-sage);
    transition: opacity 0.2s;
  }

  .footer-address a:hover {
    opacity: 1;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-5) 0;
    text-align: center;
    font-size: 0.8rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
