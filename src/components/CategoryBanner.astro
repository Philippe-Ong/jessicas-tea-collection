---
import type { Energy } from '../data/products';

interface Props {
  energy: Energy;
}

const { energy } = Astro.props;

const config: Record<Energy, { label: string; bgColor: string }> = {
  waermend: { label: 'WÄRMEND', bgColor: 'var(--color-terracotta-banner)' },
  kuehlend: { label: 'KÜHLEND', bgColor: 'var(--color-cool)' },
  neutral: { label: 'AUSGLEICHEND', bgColor: 'var(--color-sage)' },
};

const { label, bgColor } = config[energy];
---
<div class="category-banner" style={`background-color: ${bgColor};`}>
  {energy === 'waermend' && (
    <svg width="14" height="18" viewBox="0 0 14 18" fill="none" aria-hidden="true">
      <path d="M7 0C7 0 1 6 1 10.5C1 13.5 3.5 16 7 16C10.5 16 13 13.5 13 10.5C13 6 7 0 7 0Z" fill="white"/>
      <path d="M5 12C5 12 5.5 10 7 10C8.5 10 9 12 9 12" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  )}
  {energy === 'kuehlend' && (
    <svg width="14" height="18" viewBox="0 0 14 18" fill="none" aria-hidden="true">
      <path d="M7 0L7 10M7 10L3 7M7 10L11 7M7 10L7 16M7 16L3 13M7 16L11 13" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  )}
  {energy === 'neutral' && (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M9 1L9 3M9 3C6 3 3 5 3 9C3 13 6 15 9 15C12 15 15 13 15 9C15 5 12 3 9 3Z" stroke="white" stroke-width="1.5"/>
      <path d="M9 6L9 10M9 10L7 8.5M9 10L11 8.5" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  )}
  <span class="banner-label">{label}</span>
</div>

<style>
  .category-banner {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 8px 8px 0 0;
  }

  .banner-label {
    font-family: var(--font-sans);
    line-height: 1;
  }
</style>
