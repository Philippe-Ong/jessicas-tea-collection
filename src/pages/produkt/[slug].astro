---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CategoryBanner from '../../components/CategoryBanner.astro';
import PillButton from '../../components/PillButton.astro';
import { products, getSimilarProducts } from '../../data/products';
import { getCategoryName } from '../../data/categories';
import { empfindungen } from '../../data/empfindungen';
import type { Product } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p, similar: getSimilarProducts(p, 4) },
  }));
}

interface Props {
  product: Product;
  similar: Product[];
}

const { product, similar } = Astro.props;
const categoryName = getCategoryName(product.category);
const allImages = product.images && product.images.length > 0 ? product.images : product.image ? [product.image] : [];
const displayImage = allImages[0];

// Accessories (excluding itself)
import { getAccessoryProducts } from '../../data/products';
const accessories = getAccessoryProducts();

// Matching empfindungen for this product
const matchingEmpfindungen = empfindungen.filter((e) =>
  product.empfindungen.includes(e.slug)
);
---

<BaseLayout
  title={`${product.nameDe} – ${categoryName}`}
  description={product.shortDesc}
  image={displayImage}
  type="product"
>
  <div class="container page-container">
    <Breadcrumb
      items={[
        { label: 'Startseite', href: '/' },
        { label: categoryName, href: `/kategorie/${product.category}` },
        { label: product.nameDe },
      ]}
    />

    <!-- Two-column product layout -->
    <div class="product-layout">
      <!-- Left: Gallery -->
      <div class="product-gallery">
        {allImages.length > 0 ? (
          <>
            <div class="gallery-main">
              <img src={allImages[0]} alt={product.nameDe} />
            </div>
            {allImages.length > 1 && (
              <div class="gallery-thumbnails">
                {allImages.map((img) => (
                  <button class="gallery-thumb" aria-label="Bildvorschau">
                    <img src={img} alt="" />
                  </button>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="gallery-placeholder">
            <span class="placeholder-watermark">{product.nameCn}</span>
          </div>
        )}
      </div>

      <!-- Right: Product Info -->
      <div class="product-info">
        <CategoryBanner energy={product.energy} />

        <h1 class="product-name">{product.nameDe}</h1>

        <div class="product-name-cn-wrapper">
          <span class="product-name-cn">{product.nameCn}</span>
        </div>

        {product.nameLatin && (
          <p class="product-name-latin">{product.nameLatin}</p>
        )}

        <div class="product-price">
          <span class="price-main">CHF {product.price.toFixed(2)} · {product.weight}</span>
        </div>
        <p class="price-vat">inkl. {2.5}% MwSt</p>

        <!-- Quantity selector and add to cart -->
        <div class="product-actions">
          <div class="quantity-selector">
            <button class="qty-btn qty-minus" aria-label="Weniger">−</button>
            <input type="number" class="qty-input" value="1" min="1" aria-label="Menge" />
            <button class="qty-btn qty-plus" aria-label="Mehr">+</button>
          </div>

          <button
            class="add-to-cart"
            data-slug={product.slug}
            data-name={product.nameDe}
            data-cn={product.nameCn}
            data-price={product.price}
          >
            In den Warenkorb
          </button>
        </div>

        <!-- Accessories encart -->
        {product.category !== 'zubehoer' && accessories.length > 0 && (
          <div class="accessories-encart">
            <h3 class="accessories-title">Zubehör</h3>
            <div class="accessories-list">
              {accessories.map((a) => (
                <a href={`/produkt/${a.slug}`} class="accessory-link">
                  {a.nameDe}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Info blocks -->
    <div class="info-blocks">
      <!-- Beschreibung -->
      <section class="info-block">
        <h2 class="info-block-title">Beschreibung</h2>
        <p class="info-block-text">{product.beschreibung}</p>
      </section>

      <!-- TCM-Einordnung -->
      <section class="info-block">
        <h2 class="info-block-title">TCM-Einordnung</h2>
        <p class="info-block-text">{product.tcmEinordnung}</p>
      </section>

      <!-- Zubereitung -->
      <section class="info-block">
        <h2 class="info-block-title">Zubereitung</h2>
        <p class="info-block-text">{product.zubereitung}</p>
      </section>

      <!-- Zutaten / Allergie-Hinweis -->
      <section class="info-block">
        <h2 class="info-block-title">Zutaten / Allergie-Hinweis</h2>
        <p class="info-block-text">{product.zutaten}</p>
        <p class="allergie-hinweis">
          Bitte beachten Sie die vollständige <a href="/allergie-hinweis">Zutatenliste auf der Allergie-Hinweis Seite</a>.
        </p>
      </section>

      <!-- Finde deinen Tee encart -->
      {matchingEmpfindungen.length > 0 && (
        <section class="info-block finde-encart-block">
          <h2 class="info-block-title">Finde deinen Tee</h2>
          <p class="info-block-text">
            Dieser Tee passt zu folgenden Empfindungen:
          </p>
          <div class="empfindung-links">
            {matchingEmpfindungen.map((e) => (
              <a href={`/finde-deinen-tee/${e.slug}`} class="empfindung-link">
                {e.title}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Ähnliche Tees -->
      {similar.length > 0 && (
        <section class="info-block">
          <h2 class="info-block-title">Ähnliche Tees</h2>
          <div class="similar-grid">
            {similar.map((p) => <ProductCard product={p} />)}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.nameDe,
  "description": product.shortDesc,
  "image": displayImage ? [displayImage] : undefined,
  "offers": {
    "@type": "Offer",
    "price": product.price.toFixed(2),
    "priceCurrency": "CHF",
    "availability": "https://schema.org/InStock"
  }
})} />

<style>
  .page-container {
    padding-top: var(--space-7);
    padding-bottom: var(--space-8);
  }

  /* ── Two-column layout ── */
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }

  /* ── Gallery ── */
  .product-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .gallery-main {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-card);
    background: var(--color-sand);
  }

  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-placeholder {
    aspect-ratio: 4 / 3;
    background: var(--color-sand);
    border-radius: var(--radius-card);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-watermark {
    font-family: var(--font-serif);
    font-size: 5rem;
    opacity: 0.2;
    color: var(--color-text);
    user-select: none;
    line-height: 1;
  }

  .gallery-thumbnails {
    display: flex;
    gap: var(--space-2);
  }

  .gallery-thumb {
    width: 80px;
    height: 60px;
    overflow: hidden;
    border: 2px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    padding: 0;
    background: var(--color-sand);
    transition: border-color 0.2s;
  }

  .gallery-thumb:hover {
    border-color: var(--color-terracotta);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Product info ── */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .product-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }

  .product-name-cn-wrapper {
    position: relative;
  }

  .product-name-cn {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 400;
    opacity: 0.2;
    color: var(--color-text);
    line-height: 1;
    user-select: none;
  }

  .product-name-latin {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text-light);
  }

  .product-price {
    margin-top: var(--space-2);
  }

  .price-main {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-olive);
  }

  .price-vat {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-top: 2px;
  }

  /* ── Quantity & Add to cart ── */
  .product-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }

  .quantity-selector {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    overflow: hidden;
    width: fit-content;
  }

  .qty-btn {
    width: 44px;
    height: 44px;
    border: none;
    background: var(--color-cream);
    font-size: 1.25rem;
    cursor: pointer;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .qty-btn:hover {
    background: var(--color-sand);
  }

  .qty-input {
    width: 60px;
    height: 44px;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    text-align: center;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    background: var(--color-white);
    -moz-appearance: textfield;
  }

  .qty-input::-webkit-inner-spin-button,
  .qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .add-to-cart {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 14px 36px;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    background: var(--color-terracotta);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    width: fit-content;
  }

  .add-to-cart:hover {
    background: var(--color-terracotta-banner);
  }

  /* ── Accessories ── */
  .accessories-encart {
    background: var(--color-cream);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-5);
    margin-top: var(--space-2);
  }

  .accessories-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }

  .accessories-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .accessory-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-sage);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .accessory-link:hover {
    color: var(--color-terracotta);
  }

  /* ── Info blocks ── */
  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .info-block {
    padding: var(--space-7) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .info-block:last-child {
    border-bottom: none;
  }

  .info-block-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .info-block-text {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .allergie-hinweis {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-top: var(--space-4);
  }

  .allergie-hinweis a {
    color: var(--color-sage);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .allergie-hinweis a:hover {
    color: var(--color-terracotta);
  }

  /* ── Finde deinen Tee encart ── */
  .finde-encart-block {
    background: #F8F6F0;
    border-radius: var(--radius-card);
    padding: var(--space-6);
    border-left: 4px solid var(--color-sage);
  }

  .empfindung-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  .empfindung-link {
    display: inline-block;
    padding: 8px 16px;
    background: var(--color-white);
    border: 1px solid var(--color-sage);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-sage);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .empfindung-link:hover {
    background: var(--color-sage);
    color: var(--color-white);
  }

  /* ── Similar products grid ── */
  .similar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 1024px) {
    .similar-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .similar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
